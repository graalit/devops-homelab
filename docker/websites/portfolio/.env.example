# ══════════════════════════════════════════════
# PORTFOLIO — Variables d'environnement
# Copier en .env et remplir les vraies valeurs
# NE JAMAIS commiter .env dans Git !
# ══════════════════════════════════════════════

# PostgreSQL (partagé avec l'infra homelab)
POSTGRES_USER=homelab
POSTGRES_PASSWORD=VOTRE_MOT_DE_PASSE_POSTGRES

# JWT — générer avec : openssl rand -hex 64
PORTFOLIO_JWT_SECRET=CHANGEZ_MOI_64_CHARS_MINIMUM
